DASHSCOPE_API_KEY=your_dashscope_api_key
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=rag_demo_v1
APP_PORT=18088
UPLOAD_DIR=data/uploads
CHUNK_SIZE=500
CHUNK_OVERLAP=50
EMBEDDING_DIM=1536
EMBEDDING_BATCH_SIZE=10
RERANKER_BACKEND=bge
RERANKER_MODEL=E:\software\model\bge-reranker-base
# RERANKER_BACKEND=llm         # 改成 llm 用通义打分兜底，无需本地模型
# RERANKER_CANDIDATE_K=20      # Milvus 粗召回候选数
# RERANKER_USE_FP16=false      # CPU 推理保持 false
